# Shared
APP_ENV=development

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///./style_translator.db
ASSETS_DIR=./data/assets
# Back-compat alias (optional): ASSETS_ROOT is also accepted and maps to ASSETS_DIR.
ASSETS_ROOT=./data/assets
MAX_UPLOAD_MB=10
# Back-compat alias (optional): MAX_UPLOAD_BYTES is still accepted.
MAX_UPLOAD_BYTES=10485760
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
DEBUG=0

# Web
VITE_API_URL=http://localhost:8000

# Optional: image generation
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=high

# Optional: style analysis
OPENAI_ANALYSIS_MODEL=
